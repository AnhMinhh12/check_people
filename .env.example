# =============================================================================
# Sentinel Warden AI — Enterprise V5.5 (HTMP_AI_Systems Layout)
# Tệp mẫu biến môi trường (.env.example)
# Sao chép thành .env và điền thông tin thực tế trước khi chạy.
# =============================================================================

# --- Camera Streams ---
# Khai báo camera theo cặp RTSP_URL{i} + CAMERA_NAME{i} (hỗ trợ tối đa 100)
RTSP_URL1=rtsp://admin:password@192.168.1.10:554/Streaming/Channels/102
CAMERA_NAME1=Máy Hàn 01

RTSP_URL2=rtsp://admin:password@192.168.1.11:554/Streaming/Channels/102
CAMERA_NAME2=Khu Vực Bốc Xếp

# --- Server Configuration ---
FLASK_PORT=5000
FLASK_HOST=0.0.0.0
FLASK_DEBUG=False

# --- AI Model Settings ---
MODEL_PATH=models/yolov8s.onnx
CONFIDENCE_THRESHOLD=0.15
ALARM_DELAY_SECONDS=5.0
AI_MAX_FPS=10

# --- Database (SQLAlchemy URL) ---
# SQLite  (Dev):  sqlite:///data/sentinel.db
# MySQL   (Prod): mysql+pymysql://user:password@localhost:3306/sentinel_db
DATABASE_URL=sqlite:///data/sentinel.db

# --- Data Storage ---
VIOLATIONS_DIR=data/violations
LOGS_DIR=logs

# --- Integrations (Tùy chọn) ---
# TELEGRAM_BOT_TOKEN=your_bot_token_here
# TELEGRAM_CHAT_ID=your_chat_id_here
# ERP_API_URL=https://erp.company.com/api
# ERP_API_KEY=your_api_key_here
